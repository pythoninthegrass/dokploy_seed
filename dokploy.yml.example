# yaml-language-server: $schema=https://raw.githubusercontent.com/pythoninthegrass/icarus/main/schemas/dokploy.schema.json

project:
  name: my-project
  description: |
    My project deployed via Dokploy

  # Which apps receive the filtered .env file
  env_targets: [web, worker]

  # Deploy waves: sequential outer list, parallel inner lists
  # Wave 1 completes before wave 2 starts
  deploy_order:
    - [redis]
    - [web, worker]

# GitHub defaults for all github-sourced apps
# Omit this entire section for Docker-only projects
github:
  owner: your-org
  repository: your-repo
  branch: main

# Per-environment overrides (merged into base config at runtime)
environments:
  prod:
    apps:
      web:
        domain:
          host: app.example.com
          port: 8000
          https: true
          certificateType: letsencrypt
        autoDeploy: true
        replicas: 2
  dev:
    github:
      branch: develop
    apps:
      web:
        domain:
          host: app-dev.example.com
          port: 8000
          https: true
          certificateType: letsencrypt

apps:
  - name: redis
    source: docker
    dockerImage: redis:7-alpine
    volumes:
      - source: redis_data
        target: /data
        type: volume

  - name: web
    source: github
    # Build settings (defaults shown)
    buildType: dockerfile         # dockerfile | nixpacks | static | heroku_buildpacks | paketo_buildpacks | railpack
    dockerfile: Dockerfile         # Dockerfile path (buildType: dockerfile only)
    # dockerContextPath: ""      # Docker build context (buildType: dockerfile only)
    # dockerBuildStage: ""       # Multi-stage target (buildType: dockerfile only)
    # publishDirectory: ""       # Output dir (buildType: static only)
    buildPath: /                 # Build path for GitHub provider
    triggerType: push            # push | manual
    autoDeploy: true             # Auto-deploy on push
    # replicas: 1                # Number of replicas
    # watchPaths:                # File paths to watch for auto-deploy
    #   - "src/**"
    #   - Dockerfile
    # create_env_file: false      # Write env vars to .env in container workdir

  - name: worker
    source: github
    command: >-
      celery -A myproject worker
      --loglevel=INFO --concurrency=4

  # Docker app with {ref} resolution — {redis} is replaced with the
  # Dokploy-assigned appName for the "redis" app at setup time
  - name: monitor
    source: docker
    dockerImage: mher/flower:2.0.1
    command: >-
      celery --broker=redis://{redis}:6379/0 flower
      --port=5555 --address=0.0.0.0
    env: |
      TZ=UTC
      CELERY_BROKER_URL=redis://{redis}:6379/0
