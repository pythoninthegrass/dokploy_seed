# Dokploy API connection
DOKPLOY_URL=https://dokploy.example.com
DOKPLOY_API_KEY=your-api-key-here

# Optional: override default environment (defaults to 'dev' if unset)
# DOKPLOY_ENV=prod

# SSH
DOKPLOY_SSH_HOST=
DOKPLOY_SSH_USER=
DOKPLOY_SSH_PORT=22

# Optional: exclude env vars when pushing .env to apps
# (comma-separated, merged with built-in defaults)
# Trailing _ or * = prefix match; otherwise = exact match
# ENV_EXCLUDES=DEV,DEBUG,MY_LOCAL_,SECRET*
