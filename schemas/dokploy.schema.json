{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/pythoninthegrass/icarus/main/schemas/dokploy.schema.json",
  "title": "Dokploy deployment config",
  "type": "object",
  "required": [
    "project",
    "apps"
  ],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "required": [
        "name",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Dokploy project name"
        },
        "description": {
          "type": "string",
          "description": "Dokploy project description"
        },
        "env_targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "App names that receive the filtered .env file"
        },
        "deploy_order": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "Deploy waves: outer list is sequential, inner lists are parallel"
        }
      }
    },
    "github": {
      "type": "object",
      "required": [
        "owner",
        "repository",
        "branch"
      ],
      "additionalProperties": false,
      "description": "GitHub defaults for all github-sourced apps. Omit for Docker-only projects.",
      "properties": {
        "owner": {
          "type": "string",
          "description": "GitHub org or user"
        },
        "repository": {
          "type": "string",
          "description": "Repository name (not owner/repo \u2014 Dokploy prepends owner)"
        },
        "branch": {
          "type": "string",
          "description": "Branch to deploy from"
        }
      }
    },
    "environments": {
      "type": "object",
      "description": "Per-environment overrides. Each key is an environment name (e.g. prod, dev).",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "github": {
            "type": "object",
            "additionalProperties": false,
            "description": "Override github branch/owner/repo for this environment.",
            "properties": {
              "owner": {
                "type": "string",
                "description": "GitHub org or user"
              },
              "repository": {
                "type": "string",
                "description": "Repository name"
              },
              "branch": {
                "type": "string",
                "description": "Branch to deploy from"
              }
            }
          },
          "apps": {
            "type": "object",
            "description": "Per-app overrides keyed by app name.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "command": {
                  "type": "string",
                  "description": "Command override"
                },
                "env": {
                  "type": "string",
                  "description": "Per-app env vars override"
                },
                "dockerImage": {
                  "type": "string",
                  "description": "Docker image override"
                },
                "domain": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/domain"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/$defs/domain"
                      }
                    }
                  ],
                  "description": "Domain config override"
                },
                "buildType": {
                  "type": "string",
                  "enum": [
                    "dockerfile",
                    "nixpacks",
                    "static",
                    "heroku",
                    "docker"
                  ],
                  "description": "Application build type"
                },
                "dockerfile": {
                  "type": "string",
                  "description": "Dockerfile path (for buildType: dockerfile)"
                },
                "dockerContextPath": {
                  "type": "string",
                  "description": "Docker build context path (for buildType: dockerfile)"
                },
                "dockerBuildStage": {
                  "type": "string",
                  "description": "Docker build target stage (for buildType: dockerfile)"
                },
                "publishDirectory": {
                  "type": "string",
                  "description": "Publish directory (for buildType: static)"
                },
                "autoDeploy": {
                  "type": "boolean",
                  "description": "Enable auto-deploy on push"
                },
                "replicas": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Number of app replicas"
                },
                "buildPath": {
                  "type": "string",
                  "description": "Build path for GitHub provider (default: /)"
                },
                "triggerType": {
                  "type": "string",
                  "enum": [
                    "push",
                    "manual"
                  ],
                  "description": "GitHub trigger type"
                },
                "watchPaths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "File paths to watch for auto-deploy triggers"
                },
                "ports": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/port"
                  },
                  "description": "TCP/UDP port mappings override"
                },
                "schedules": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/schedule"
                  },
                  "description": "Cron jobs that run commands inside the app container"
                },
                "security": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/security_entry"
                  },
                  "description": "Basic auth credentials override"
                },
                "redirects": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/redirect"
                  },
                  "description": "URL redirects (regex-based 301/302)"
                }
              }
            }
          }
        }
      }
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique app name within the project"
          },
          "source": {
            "type": "string",
            "enum": [
              "docker",
              "github"
            ],
            "description": "App source type"
          },
          "dockerImage": {
            "type": "string",
            "description": "Docker image (required when source is docker)"
          },
          "command": {
            "type": "string",
            "description": "Command override. Supports {app_name} refs resolved to Dokploy appName at runtime."
          },
          "env": {
            "type": "string",
            "description": "Per-app env vars (not the project .env). Supports {app_name} refs."
          },
          "domain": {
            "oneOf": [
              {
                "$ref": "#/$defs/domain"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/domain"
                }
              }
            ],
            "description": "Domain config \u2014 single object or list of objects"
          },
          "buildType": {
            "type": "string",
            "enum": [
              "dockerfile",
              "nixpacks",
              "static",
              "heroku_buildpacks",
              "paketo_buildpacks",
              "railpack"
            ],
            "default": "dockerfile",
            "description": "Application build type (default: dockerfile)"
          },
          "dockerfile": {
            "type": "string",
            "description": "Dockerfile path (for buildType: dockerfile, default: Dockerfile)"
          },
          "dockerContextPath": {
            "type": "string",
            "description": "Docker build context path (for buildType: dockerfile)"
          },
          "dockerBuildStage": {
            "type": "string",
            "description": "Docker build target stage (for buildType: dockerfile)"
          },
          "publishDirectory": {
            "type": "string",
            "description": "Publish directory (for buildType: static)"
          },
          "isStaticSpa": {
            "type": "boolean",
            "description": "Single Page Application mode (for buildType: static)"
          },
          "autoDeploy": {
            "type": "boolean",
            "description": "Enable auto-deploy on push"
          },
          "replicas": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of app replicas"
          },
          "buildPath": {
            "type": "string",
            "description": "Build path for GitHub provider (default: /)"
          },
          "triggerType": {
            "type": "string",
            "enum": [
              "push",
              "manual"
            ],
            "description": "GitHub trigger type (default: push)"
          },
          "watchPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "File paths to watch for auto-deploy triggers"
          },
          "create_env_file": {
            "type": "boolean",
            "default": false,
            "description": "Write env vars to a .env file in the container working directory (default: false)"
          },
          "volumes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/volume"
            },
            "description": "Persistent volume mounts for the application"
          },
          "ports": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/port"
            },
            "description": "TCP/UDP port mappings to expose beyond domain routing"
          },
          "schedules": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/schedule"
            },
            "description": "Cron jobs that run commands inside the app container"
          },
          "security": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/security_entry"
            },
            "description": "Basic auth credentials for the application"
          },
          "redirects": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/redirect"
            },
            "description": "URL redirects (regex-based 301/302)"
          }
        },
        "if": {
          "properties": {
            "source": {
              "const": "docker"
            }
          }
        },
        "then": {
          "required": [
            "dockerImage"
          ]
        }
      }
    },
    "database": {
      "type": "array",
      "description": "Database resources managed by Dokploy (postgres, mysql, mariadb, mongo, redis)",
      "items": {
        "$ref": "#/$defs/database_entry"
      }
    }
  },
  "$defs": {
    "volume": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Volume name (for type: volume) or host path (for type: bind)"
        },
        "target": {
          "type": "string",
          "description": "Mount path inside the container"
        },
        "type": {
          "type": "string",
          "enum": [
            "volume",
            "bind"
          ],
          "description": "Mount type: volume (Docker-managed) or bind (host path)"
        }
      }
    },
    "port": {
      "type": "object",
      "required": [
        "publishedPort",
        "targetPort"
      ],
      "additionalProperties": false,
      "properties": {
        "publishedPort": {
          "type": "integer",
          "description": "Host port to publish"
        },
        "targetPort": {
          "type": "integer",
          "description": "Container port to map to"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "tcp",
            "udp"
          ],
          "default": "tcp",
          "description": "Transport protocol (default: tcp)"
        },
        "publishMode": {
          "type": "string",
          "enum": [
            "ingress",
            "host"
          ],
          "default": "ingress",
          "description": "Swarm publish mode (default: ingress)"
        }
      }
    },
    "schedule": {
      "type": "object",
      "required": [
        "name",
        "cronExpression",
        "command"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Schedule job name"
        },
        "cronExpression": {
          "type": "string",
          "description": "Standard 5-field cron expression (minute hour day month weekday)"
        },
        "command": {
          "type": "string",
          "description": "Command to run inside the app container"
        },
        "shellType": {
          "type": "string",
          "enum": [
            "bash",
            "sh"
          ],
          "default": "bash",
          "description": "Shell to use for command execution (default: bash)"
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone (e.g. America/Chicago)"
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether the schedule is active (default: true)"
        }
      }
    },
    "security_entry": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "additionalProperties": false,
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1,
          "description": "Basic auth username"
        },
        "password": {
          "type": "string",
          "minLength": 1,
          "description": "Basic auth password"
        }
      }
    },
    "redirect": {
      "type": "object",
      "required": [
        "regex",
        "replacement",
        "permanent"
      ],
      "additionalProperties": false,
      "properties": {
        "regex": {
          "type": "string",
          "minLength": 1,
          "description": "Regex pattern to match incoming URL paths"
        },
        "replacement": {
          "type": "string",
          "minLength": 1,
          "description": "Replacement URL or path (supports regex capture groups)"
        },
        "permanent": {
          "type": "boolean",
          "description": "Use 301 (true) or 302 (false) status code"
        }
      }
    },
    "domain": {
      "type": "object",
      "required": [
        "host",
        "port",
        "https",
        "certificateType"
      ],
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "description": "Domain hostname"
        },
        "port": {
          "type": "integer",
          "description": "Container port to expose"
        },
        "https": {
          "type": "boolean",
          "description": "Enable HTTPS"
        },
        "certificateType": {
          "type": "string",
          "enum": [
            "none",
            "letsencrypt"
          ],
          "description": "TLS certificate type"
        },
        "path": {
          "type": "string",
          "description": "URL path (default: /)"
        },
        "internalPath": {
          "type": "string",
          "description": "Internal routing path (default: /)"
        },
        "stripPath": {
          "type": "boolean",
          "description": "Strip path prefix before forwarding (default: false)"
        }
      }
    },
    "database_entry": {
      "type": "object",
      "required": [
        "name",
        "type",
        "databasePassword"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique database name within the project"
        },
        "type": {
          "type": "string",
          "enum": [
            "postgres",
            "mysql",
            "mariadb",
            "mongo",
            "redis"
          ],
          "description": "Database engine type"
        },
        "dockerImage": {
          "type": "string",
          "description": "Docker image override (defaults: postgres:16, mysql:8, mariadb:11, mongo:7, redis:7)"
        },
        "databaseName": {
          "type": "string",
          "description": "Database name to create (required for postgres, mysql, mariadb)"
        },
        "databaseUser": {
          "type": "string",
          "description": "Database user (required for postgres, mysql, mariadb, mongo)"
        },
        "databasePassword": {
          "type": "string",
          "description": "Database password"
        },
        "databaseRootPassword": {
          "type": "string",
          "description": "Root password (required for mysql and mariadb)"
        },
        "description": {
          "type": "string",
          "description": "Optional description for the database"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["postgres", "mysql", "mariadb"]
              }
            }
          },
          "then": {
            "required": ["databaseName", "databaseUser"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["mysql", "mariadb"]
              }
            }
          },
          "then": {
            "required": ["databaseRootPassword"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "mongo"
              }
            }
          },
          "then": {
            "required": ["databaseUser"]
          }
        }
      ]
    }
  }
}
